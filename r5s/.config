# Target system - Rockchip RK3568
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r5s=y
CONFIG_TARGET_ROOTFS_PARTSIZE=960

# Root filesystem types
CONFIG_TARGET_ROOTFS_INITRAMFS=n
CONFIG_TARGET_ROOTFS_CPIOGZ=n
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TAR=y

# Kernel modules (essential for R5S)
CONFIG_PACKAGE_kmod-dwmac-rockchip=y
CONFIG_PACKAGE_kmod-phy-rockchip-naneng=y
CONFIG_PACKAGE_kmod-phy-rockchip-inno-usb2=y
CONFIG_PACKAGE_kmod-pcie-rockchip=y
CONFIG_PACKAGE_kmod-usb-dwc3-of-simple=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-nvme=y
CONFIG_PACKAGE_kmod-rtc-hym8563=y
CONFIG_PACKAGE_kmod-hwmon-pwmfan=y
CONFIG_PACKAGE_kmod-thermal=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-phy-realtek=y

# Disable Amlogic-specific package
CONFIG_PACKAGE_luci-app-amlogic=n

# Remove WiFi (R5S has no built-in WiFi)
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_kmod-brcmfmac=n
CONFIG_PACKAGE_kmod-brcmutil=n
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_wpa-cli=n
CONFIG_PACKAGE_wpad-basic=n

# Basic packages
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_btrfs-progs=y
CONFIG_PACKAGE_bsdtar=y
CONFIG_PACKAGE_chattr=y
CONFIG_PACKAGE_lsattr=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_perl=y
CONFIG_PACKAGE_perlbase-httpd=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_pigz=y
CONFIG_PACKAGE_zstd=y

# LuCI applications
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-ksmbd=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-ssl-openssl=y

# Other utilities
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_rsync=y
CONFIG_PACKAGE_sshpass=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_sudo=y
CONFIG_PACKAGE_logrotate=y

# Python3 support
CONFIG_PACKAGE_python3=y
CONFIG_PACKAGE_python3-pip=y

# Filesystem tools
CONFIG_BTRFS_PROGS_ZSTD=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_xfs-mkfs=y
CONFIG_PACKAGE_xfs-fsck=y

# Network
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_nftables-nojson=y
CONFIG_PACKAGE_firewall4=y

# Add extra packages (optional)
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y